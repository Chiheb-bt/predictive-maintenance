# Sentinel: Industrial AI Predictive Maintenance
# Environment Configuration Template

# --- Model & Inference ---
# Path to the trained sklearn Pipeline (.pkl)
MODEL_PATH=model.pkl

# Decision threshold [0, 1]. If unset, auto-loads from artifacts/meta.json.
# Fallback is 0.5.
MODEL_THRESHOLD=0.5

# --- Security ---
# API Key for /predict and /predict/batch endpoints.
# If left empty, authentication is DISABLED (dev-only!).
# Ensure this is a strong secret in production.
API_KEY=

# --- Networking ---
# The port the FastAPI server will bind to.
PORT=8000

# Comma-separated list of allowed CORS origins.
# Use '*' only for public experimentation.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
