# Copy this file to .env and fill in the values before running the server.
# The server reads these at startup. None are required for local development
# unless you want to enable auth or change the model path.

# Path to the trained sklearn Pipeline. Defaults to model.pkl in the project root.
MODEL_PATH=model.pkl

# Decision threshold for the failure class. If not set, the value from
# artifacts/meta.json is used, falling back to 0.5.
MODEL_THRESHOLD=

# API key for protecting the /predict endpoint.
# If this is empty or unset, authentication is disabled and a startup
# warning is logged. Set it to any secret string to enable key-based auth.
# Clients send: X-Api-Key: <your-key>
API_KEY=

# Comma-separated list of allowed CORS origins.
# Use '*' only in development — a startup warning fires if you leave it here.
ALLOWED_ORIGINS=http://localhost:3000

# Server port (default: 8000).
PORT=8000
